# Database (Neon PostgreSQL)
# Pooled connection string lazımdır (sonu "-pooler" olan)
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# NextAuth — secret yarat: openssl rand -base64 32
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Cloudflare R2
# CF_ACCOUNT_ID — endpoint URL-dən çıxar: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
CF_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret"
R2_BUCKET_NAME="furniture-media"
# Bucket Settings → Public Access bölməsindən: r2.dev subdomain və ya custom domain
R2_PUBLIC_URL="https://media.yourdomain.com"
